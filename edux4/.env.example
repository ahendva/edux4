# Firebase configuration - copy to .env and fill in your values
# Never commit .env to git

EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_IOS_APP_ID=1:your_sender_id:ios:your_app_id
EXPO_PUBLIC_FIREBASE_ANDROID_APP_ID=1:your_sender_id:android:your_app_id

# PowerSchool API configuration
EXPO_PUBLIC_PS_BASE_URL=https://your-district.powerschool.com
PS_CLIENT_ID=your_powerschool_client_id
PS_CLIENT_SECRET=your_powerschool_client_secret
